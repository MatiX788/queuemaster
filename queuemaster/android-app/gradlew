#!/bin/sh
# Gradle wrapper script for UN*X
APP_HOME=$(cd "$(dirname "$0")" && pwd)
export APP_HOME

JAVA_EXEC="java"
if [ -n "$JAVA_HOME" ]; then
    JAVA_EXEC="$JAVA_HOME/bin/java"
fi

exec "$JAVA_EXEC" -classpath "$APP_HOME/gradle/wrapper/gradle-wrapper.jar" \
    org.gradle.wrapper.GradleWrapperMain "$@"
